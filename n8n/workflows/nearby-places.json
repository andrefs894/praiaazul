                  {
                      "parameters":  {
                                         "mode":  "runOnceForAllItems",
                                         "language":  "javaScript",
                                         "jsCode":  "// runOnceForAllItems: process all merged beach+API items, expand into one item per top place.\n// runOnceForEachItem cannot return arrays in Code v2 â€” use this mode instead.\nfunction haversineMeters(lat1, lon1, lat2, lon2) {\n  const R = 6371000;\n  const dLat = (lat2 - lat1) * Math.PI / 180;\n  const dLon = (lon2 - lon1) * Math.PI / 180;\n  const a = Math.sin(dLat / 2) ** 2 +\n            Math.cos(lat1 * Math.PI / 180) * Math.cos(lat2 * Math.PI / 180) *\n            Math.sin(dLon / 2) ** 2;\n  return R * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));\n}\n\nfunction simplifyType(types, primaryType) {\n  const all = new Set([primaryType, ...(types || [])].filter(Boolean));\n  if (all.has(\u0027restaurant\u0027)) return \u0027restaurante\u0027;\n  if (all.has(\u0027bar\u0027))        return \u0027bar\u0027;\n  if (all.has(\u0027cafe\u0027))       return \u0027cafe\u0027;\n  return null;\n}\n\nconst out = [];\n\nfor (const inp of $input.all()) {\n  const praia = inp.json;\n  const places = praia.places ?? [];\n\n  if (praia.error) {\n    console.log(`Praia ${praia.id}: API error â€” ${praia.error.message ?? JSON.stringify(praia.error)}`);\n    continue;\n  }\n\n  if (places.length === 0) {\n    console.log(`Praia ${praia.id}: no nearby places`);\n    continue;\n  }\n\n  const scored = places.map(pl =\u003e {\n    const lat = pl.location?.latitude;\n    const lng = pl.location?.longitude;\n    const rating = pl.rating ?? 0;\n    const reviews = pl.userRatingCount ?? 0;\n    const score = rating * Math.log10(reviews + 1);\n    const distance = (lat != null \u0026\u0026 lng != null)\n      ? haversineMeters(praia.latitude, praia.longitude, lat, lng)\n      : null;\n    const photoName = pl.photos?.[0]?.name ?? null;\n    return {\n      place_id: pl.id,\n      nome: pl.displayName?.text ?? null,\n      tipo: simplifyType(pl.types, pl.primaryType),\n      rating: pl.rating ?? null,\n      review_count: pl.userRatingCount ?? null,\n      latitude: lat ?? null,\n      longitude: lng ?? null,\n      distancia_metros: distance != null ? Math.round(distance) : null,\n      endereco: pl.formattedAddress ?? null,\n      photoName,\n      score,\n    };\n  });\n\n  // Exclude surf schools and sports facilities misclassified as bars/cafes by Google\n  const SURF_KEYWORDS = [\u0027surf\u0027, \u0027kitesurf\u0027, \u0027windsurf\u0027, \u0027wakeboard\u0027];\n  const SPORTS_TYPES = new Set([\u0027sports_school\u0027, \u0027sports_complex\u0027, \u0027sports_club\u0027, \u0027fitness_center\u0027, \u0027gym\u0027]);\n  function isDesporto(place, nome) {\n    const nm = nome?.toLowerCase() ?? \u0027\u0027;\n    const types = new Set([place.primaryType, ...(place.types || [])].filter(Boolean));\n    return SURF_KEYWORDS.some(k =\u003e nm.includes(k)) || [...SPORTS_TYPES].some(t =\u003e types.has(t));\n  }\n\n  const valid = scored.filter(s =\u003e s.nome \u0026\u0026 s.tipo \u0026\u0026 !isDesporto(places.find(pl =\u003e pl.id === s.place_id) ?? {}, s.nome));\n  valid.sort((a, b) =\u003e b.score - a.score);\n\n  // Keep up to 5 per type so filter pills have enough results for each category.\n  const byType = { restaurante: [], bar: [], cafe: [] };\n  for (const s of valid) {\n    if (s.tipo \u0026\u0026 byType[s.tipo] \u0026\u0026 byType[s.tipo].length \u003c 5) {\n      byType[s.tipo].push(s);\n    }\n  }\n  const top = [...byType.restaurante, ...byType.bar, ...byType.cafe];\n\n  console.log(`Praia ${praia.id}: kept ${top.length} of ${places.length} candidates`);\n\n  for (const t of top) {\n    out.push({\n      json: {\n        praia_id: Number(praia.id),\n        google_place_id: t.place_id,\n        nome: t.nome,\n        tipo: t.tipo,\n        rating: t.rating,\n        review_count: t.review_count,\n        latitude: t.latitude,\n        longitude: t.longitude,\n        distancia_metros: t.distancia_metros,\n        endereco: t.endereco,\n        photoName: t.photoName,\n      }\n    });\n  }\n}\n\nconsole.log(`Total place items to resolve: ${out.length}`);\nreturn out;"
                                     },
