                                         "language":  "javaScript",
                                         "jsCode":  "// Pair each resolved photoUri with the corresponding place metadata (by position).\nconst out = [];\n\nfor (const inp of $input.all()) {\n  const item = inp.json;\n\n  out.push({\n    json: {\n      praia_id: item.praia_id,\n      google_place_id: item.google_place_id,\n      nome: item.nome,\n      tipo: item.tipo,\n      rating: item.rating,\n      review_count: item.review_count,\n      foto_url: item.photoUri ?? null,\n      foto_attr: null,\n      latitude: item.latitude,\n      longitude: item.longitude,\n      distancia_metros: item.distancia_metros,\n      endereco: item.endereco,\n    }\n  });\n}\n\nreturn out;"
                                     },
                      "id":  "node-code-combine",
                      "name":  "Combinar Metadados",
                      "type":  "n8n-nodes-base.code",
                      "typeVersion":  2,
