                  {
                      "parameters":  {
                                         "mode":  "runOnceForAllItems",
                                         "language":  "javaScript",
                                         "jsCode":  "// Build bulk SQL: replace pontos_interesse for beaches that returned any,\n// AND mark every processed beach as verified (so beaches with zero nearby\n// places don\u0027t get re-fetched on the next run).\nconst rows = $input.all().map(i =\u003e i.json);\nconst allCandidates = $(\u0027Buscar Praias Sem Pontos\u0027).all().map(i =\u003e i.json);\nconst processedIds = [...new Set(allCandidates.map(c =\u003e Number(c.id)))];\n\nif (processedIds.length === 0) {\n  console.log(\u0027No beaches to verify\u0027);\n  return [];\n}\n\nconst esc = (v) =\u003e v == null ? \u0027NULL\u0027 : `\u0027${String(v).replace(/\u0027/g, \"\u0027\u0027\")}\u0027`;\nconst num = (v) =\u003e v == null ? \u0027NULL\u0027 : String(Number(v));\n\nlet sql = \u0027\u0027;\n\nif (rows.length \u003e 0) {\n  const praiaIdsWithPontos = [...new Set(rows.map(r =\u003e Number(r.praia_id)))];\n  const values = rows.map(r =\u003e\n    `(${num(r.praia_id)}, ${esc(r.google_place_id)}, ${esc(r.nome)}, ${esc(r.tipo)}, ${num(r.rating)}, ${num(r.review_count)}, ${esc(r.foto_url)}, ${esc(r.foto_attr)}, ${num(r.latitude)}, ${num(r.longitude)}, ${num(r.distancia_metros)}, ${esc(r.endereco)})`\n  ).join(\u0027,\\n\u0027);\n  sql += `DELETE FROM pontos_interesse WHERE praia_id IN (${praiaIdsWithPontos.join(\u0027,\u0027)});\\n`;\n  sql += `INSERT INTO pontos_interesse (praia_id, google_place_id, nome, tipo, rating, review_count, foto_url, foto_attr, latitude, longitude, distancia_metros, endereco) VALUES ${values}\\nON CONFLICT (praia_id, google_place_id) DO NOTHING;\\n`;\n}\n\n// Always mark processed beaches as verified, even if zero nearby places were found.\nsql += `UPDATE praias SET pontos_verificados_em = NOW() WHERE id IN (${processedIds.join(\u0027,\u0027)});\\n`;\n\nconsole.log(`Will write ${rows.length} places and mark ${processedIds.length} beaches as verified`);\nreturn [{ json: { sql, total: rows.length, praias: processedIds.length } }];"
                                     },
